<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="ph2m_order_withdrawal" resource="default" engine="innodb" comment="Customer order withdrawal request">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="int" name="order_id" unsigned="true" nullable="false" comment="Order ID"/>
        <column xsi:type="varchar" name="increment_id" nullable="true" length="50" comment="Order increment ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="true" comment="Customer ID"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="true" comment="Store ID"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="CDB_ORDER_WITHDRAWAL_ORDER_ID_SALES_ORDER_ENTITY_ID"
                    table="ph2m_order_withdrawal" column="order_id"
                    referenceTable="sales_order" referenceColumn="entity_id" onDelete="CASCADE"/>
        <index referenceId="CDB_ORDER_WITHDRAWAL_ORDER_ID" indexType="btree">
            <column name="order_id"/>
        </index>
        <index referenceId="CDB_ORDER_WITHDRAWAL_CUSTOMER_ID" indexType="btree">
            <column name="customer_id"/>
        </index>
    </table>
    <table name="ph2m_order_withdrawal_item" resource="default" engine="innodb" comment="Order withdrawal request item">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="int" name="withdrawal_id" unsigned="true" nullable="false" comment="Withdrawal ID"/>
        <column xsi:type="int" name="order_item_id" unsigned="true" nullable="true" comment="Order Item ID"/>
        <column xsi:type="varchar" name="sku" nullable="true" length="255" comment="SKU"/>
        <column xsi:type="varchar" name="product_name" nullable="true" length="255" comment="Product name"/>
        <column xsi:type="int" name="qty" unsigned="true" nullable="false" default="1" comment="Quantity"/>
        <column xsi:type="text" name="reason" nullable="true" comment="Reason"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="CDB_ORDER_WITHDRAWAL_ITEM_WITHDRAWAL_ID"
                    table="ph2m_order_withdrawal_item" column="withdrawal_id"
                    referenceTable="ph2m_order_withdrawal" referenceColumn="entity_id" onDelete="CASCADE"/>
        <index referenceId="CDB_ORDER_WITHDRAWAL_ITEM_WITHDRAWAL_ID" indexType="btree">
            <column name="withdrawal_id"/>
        </index>
    </table>
</schema>
