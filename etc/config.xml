<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <ph2m_order_withdrawal>
            <general>
                <enabled>1</enabled>
                <delay_days>14</delay_days>
                <use_shipment_date>1</use_shipment_date>
                <eligible_statuses>pending,processing,complete</eligible_statuses>
                <reasons>Le produit est arrivé endommagé
Mauvais produit reçu
Date de livraison estimée manquée
Délai de livraison trop long
Plus besoin de l’article
Description erronnée</reasons>
            </general>
            <email>
                <sender_identity>general</sender_identity>
                <customer_template>ph2m_order_withdrawal_email_customer_template</customer_template>
                <admin_template>ph2m_order_withdrawal_email_admin_template</admin_template>
            </email>
        </ph2m_order_withdrawal>
    </default>
</config>
