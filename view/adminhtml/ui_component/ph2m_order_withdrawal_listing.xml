<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">ph2m_order_withdrawal_listing.ph2m_order_withdrawal_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>ph2m_order_withdrawal_columns</spinner>
        <deps>
            <dep>ph2m_order_withdrawal_listing.ph2m_order_withdrawal_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="ph2m_order_withdrawal_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>PH2M_OrderWithdrawal::withdrawal</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="ph2m_order_withdrawal_listing_data_source">
            <settings>
                <requestFieldName>entity_id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="ph2m_order_withdrawal_columns">
        <column name="entity_id" sortOrder="10">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="increment_id" sortOrder="20">
            <settings>
                <filter>text</filter>
                <label translate="true">Order</label>
            </settings>
        </column>
        <column name="customer_id" sortOrder="30">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Customer ID</label>
            </settings>
        </column>
        <column name="customer_name" sortOrder="35">
            <settings>
                <filter>text</filter>
                <label translate="true">Customer</label>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date" sortOrder="40">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Created At</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="PH2M\OrderWithdrawal\Ui\Component\Listing\Column\Actions" sortOrder="50">
            <settings>
                <indexField>entity_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
