<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="customer_account"/>
    <head>
        <css src="PH2M_OrderWithdrawal::css/withdrawal.css"/>
    </head>
    <body>
        <referenceBlock name="page.main.title" remove="true"/>
        <referenceContainer name="content">
            <block class="PH2M\OrderWithdrawal\Block\Order\Form"
                   name="withdrawal.order.form"
                   template="PH2M_OrderWithdrawal::order/form.phtml">
                <arguments>
                    <argument name="withdrawal_view_model" xsi:type="object">PH2M\OrderWithdrawal\ViewModel\Withdrawal</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
