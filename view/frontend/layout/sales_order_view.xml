<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="PH2M_OrderWithdrawal::css/withdrawal.css"/>
    </head>
    <body>
        <referenceBlock name="sales.order.buttons">
            <block class="Magento\Sales\Block\Order\View"
                   name="withdrawal.order.button"
                   template="PH2M_OrderWithdrawal::order/withdrawal_button.phtml"
                   cacheable="false">
                <arguments>
                    <argument name="withdrawal_view_model" xsi:type="object">PH2M\OrderWithdrawal\ViewModel\Withdrawal</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
